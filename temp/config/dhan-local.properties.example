# Live Dhan credentials — copy to config/dhan-local.properties (gitignored)
#
# Mirrors the Trade_J config/dhan-local.properties.example template.
# Use this for: live trading, TOTP-generated tokens, runtime smoke.
#
#   dhan.clientId          — Dhan client ID (numeric)
#   dhan.accessToken       — optional bootstrap JWT (24h lifetime)
#   dhan.authMode          — STATIC | TOTP_GENERATED | WEB_RENEWABLE
#   dhan.environment       — LIVE | SANDBOX
#   dhan.restBaseUrl       — leave blank for the default (https://api.dhan.co/v2)
#   dhan.pinFile           — path to PIN file (TOTP path)
#   dhan.totpSecretFile    — path to TOTP secret file
#   dhan.tokenStateFile    — path to persisted token state (auto-managed)
#   dhan.refreshBufferMinutes — refresh when this many minutes remain
dhan.clientId=
dhan.accessToken=
dhan.authMode=TOTP_GENERATED
dhan.environment=LIVE
dhan.restBaseUrl=
dhan.pinFile=config/dhan-pin.txt
dhan.totpSecretFile=config/dhan-totp-secret.txt
dhan.tokenStateFile=runtime-dev/dhan-token-state.json
dhan.refreshBufferMinutes=10

# Live integration / runtime smoke symbols
dhan.testSymbol=NIFTY
dhan.testExchange=INDEX
dhan.testSecurityId=13
dhan.testSegment=IDX_I
dhan.historicalSymbol=NIFTY
dhan.historicalSecurityId=13
dhan.historicalSegment=IDX_I
dhan.historicalInstrument=INDEX
dhan.runtimeSymbol=NIFTY
dhan.runtimeSegment=IDX_I
