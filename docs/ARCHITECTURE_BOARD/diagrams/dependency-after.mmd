graph TD
    subgraph interfaces [interfaces]
        SDK[sdk tradex.connect]
        CLI[cli]
        REST[rest api]
    end

    subgraph application [application]
        OMS[OrderManager singleton]
        POS[PositionManager]
        RISK[RiskManager]
        EXIT[ExitManager]
        SESS[Session Universe]
    end

    subgraph domain [domain]
        INST[Instrument Equity Option]
        PORTS[ports BrokerAdapter]
        IND[indicators Wilder]
        EVT[events EventType]
    end

    subgraph infrastructure [infrastructure]
        BUS[event_bus]
        IDM[idempotency durable]
        PERS[persistence replay]
    end

    subgraph brokers [brokers plugins]
        DHAN[dhan]
        UPSTox[upstox]
        PAPER[paper]
    end

    SDK --> application
    CLI --> application
    REST --> application
    application --> domain
    application --> infrastructure
    domain --> PORTS
    brokers --> PORTS
    brokers --> infrastructure
    DHAN --> BCAP[broker_capabilities]
    UPSTox --> BCAP
    PAPER --> BCAP
