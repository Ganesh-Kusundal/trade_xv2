flowchart LR
    subgraph producers [Producers]
        DhanWS[Dhan WebSocket]
        UpstoxWS[Upstox WebSocket]
        ReplaySrc[ReplayDataSource]
    end

    subgraph normalize [Normalizer boundary]
        NORM[Quote MarketDepth builder strict]
    end

    subgraph bus [EventBus]
        TICK[TICK]
        DEPTH[DEPTH]
        TRADE[TRADE]
        TRADE_APPLIED[TRADE_APPLIED]
    end

    subgraph consumers [Consumers identical live and replay]
        IND[Indicators]
        LTP[PositionManager.update_ltp]
        RISK[RiskManager]
        EXIT[ExitManager]
        BRIDGE[MarketBridge WS out]
    end

    DhanWS --> NORM
    UpstoxWS --> NORM
    ReplaySrc --> NORM
    NORM --> TICK
    NORM --> DEPTH
    TICK --> IND
    TICK --> LTP
    TICK --> RISK
    TICK --> EXIT
    TICK --> BRIDGE
    TRADE --> OMS[OrderManager]
    OMS --> TRADE_APPLIED
    TRADE_APPLIED --> PM[PositionManager]
