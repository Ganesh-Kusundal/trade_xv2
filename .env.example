# Copy to .env.local. Do not commit .env.local.

# ═══════════════════════════════════════════════════════════════════
# Application Configuration
# ═══════════════════════════════════════════════════════════════════

# Environment profile (dev, staging, prod)
# Controls validation strictness, logging, and feature availability
APP_ENV=dev

# Logging configuration
XV2_LOG_LEVEL=INFO  # DEBUG, INFO, WARNING, ERROR, CRITICAL

# API server configuration
API_HOST=127.0.0.1
API_PORT=8000

# Database and cache
DB_PATH=runtime/tradexv2.db
CACHE_TTL=300  # Default cache TTL in seconds

# ═══════════════════════════════════════════════════════════════════
# DHAN Environment Configuration
# ═══════════════════════════════════════════════════════════════════

# DHAN LIVE credentials
DHAN_CLIENT_ID=
DHAN_ACCESS_TOKEN=
DHAN_ENVIRONMENT=LIVE  # LIVE or SANDBOX
DHAN_REST_BASE_URL=
DHAN_PIN=
DHAN_TOTP_SECRET=
DHAN_TOKEN_STATE_FILE=runtime/dhan-token-state.json
DHAN_REFRESH_BUFFER_MINUTES=10

# DHAN SANDBOX credentials (for testing order placement)
DHAN_SANDBOX_CLIENT_ID=
DHAN_SANDBOX_ACCESS_TOKEN=
DHAN_SANDBOX_ENVIRONMENT=SANDBOX
DHAN_SANDBOX_REST_BASE_URL=https://sandbox.dhan.co/v2

# DHAN live-order safety gate (default off — set to 1 to allow real orders)
DHAN_ALLOW_LIVE_ORDERS=0

# ═══════════════════════════════════════════════════════════════════
# UPSTOX Environment Configuration
# ═══════════════════════════════════════════════════════════════════

# UPSTOX LIVE credentials
UPSTOX_CLIENT_ID=
UPSTOX_CLIENT_SECRET=
UPSTOX_ACCESS_TOKEN=
UPSTOX_ANALYTICS_TOKEN=
UPSTOX_ENVIRONMENT=LIVE  # LIVE or SANDBOX
UPSTOX_AUTH_MODE=STATIC
UPSTOX_REDIRECT_URI=http://127.0.0.1:18080/callback
UPSTOX_TOKEN_STATE_FILE=runtime/upstox-token-state.json
UPSTOX_ANALYTICS_ONLY=0  # 0=full access, 1=read-only
UPSTOX_ALLOW_LIVE_ORDERS=0  # 0=blocked (default), 1=enabled
UPSTOX_MOBILE=
UPSTOX_PIN=
UPSTOX_TOTP_SECRET=
UPSTOX_TOTP_REFRESH_HOUR=8
UPSTOX_TOTP_REFRESH_MINUTE=0

# UPSTOX SANDBOX credentials (for testing)
UPSTOX_SANDBOX_CLIENT_ID=
UPSTOX_SANDBOX_CLIENT_SECRET=
UPSTOX_SANDBOX_ACCESS_TOKEN=
UPSTOX_SANDBOX_ENVIRONMENT=SANDBOX

# ═══════════════════════════════════════════════════════════════════
# API Security
# ═══════════════════════════════════════════════════════════════════

# API security — default is api_key (ENG-004). Use none only for local trusted loops.
AUTH_MODE=api_key
API_KEY=

# ═══════════════════════════════════════════════════════════════════
# Trading Runtime
# ═══════════════════════════════════════════════════════════════════

ORCHESTRATOR_DRY_RUN=1
ORCHESTRATOR_MIN_CONFIDENCE=0.7
ENABLE_INTELLIGENT_GATEWAY=0
SKIP_PARITY_GATE=0

# Intelligent Gateway Configuration
# Enable smart routing for automatic broker selection and quota management
TRADEX_SMART_ROUTING=true  # true=use intelligent routing, false=direct broker calls
TRADEX_PRIMARY_BROKER=dhan  # Primary broker for simple mode and fallback

# ═══════════════════════════════════════════════════════════════════
# Feature Flags (Experimental Features)
# ═══════════════════════════════════════════════════════════════════

# All feature flags default to false (opt-in model)
# Set to true to enable experimental features

FEATURE_SMART_ROUTING=false  # Enable intelligent broker routing
FEATURE_INTELLIGENT_GATEWAY=false  # Enable intelligent gateway
FEATURE_ADVANCED_ORDER_TYPES=false  # Enable advanced order types
FEATURE_EXPERIMENTAL_STRATEGIES=false  # Enable experimental strategies

# ═══════════════════════════════════════════════════════════════════
# Secret Encryption
# ═══════════════════════════════════════════════════════════════════

# Encryption key for token state files at rest
# Generate with: python -c 'from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())'
# Required in prod/staging profiles, optional in dev
SECRET_ENCRYPTION_KEY=

# ═══════════════════════════════════════════════════════════════════
# Environment Routing Guide
# ═══════════════════════════════════════════════════════════════════
#
# RECOMMENDED SETUP:
# - All OMS operations (place, cancel, modify orders) → Use SANDBOX
# - All GET operations (quotes, LTP, historical) → Use LIVE
#
# To test with sandbox:
#   DHAN_ENVIRONMENT=SANDBOX
#   DHAN_SANDBOX_CLIENT_ID=xxx
#   DHAN_SANDBOX_ACCESS_TOKEN=xxx
#
# To test with live read-only:
#   DHAN_ENVIRONMENT=LIVE
#   DHAN_ALLOW_LIVE_ORDERS=0
#   UPSTOX_ANALYTICS_ONLY=1
#
# Safety guards are ENABLED by default:
# - DHAN_ALLOW_LIVE_ORDERS=0 (blocks all live orders)
# - UPSTOX_ALLOW_LIVE_ORDERS=0 (blocks all live orders)
# - UPSTOX_ANALYTICS_ONLY=0 (set to 1 for read-only mode)

# Frontend: set true in staging/production builds to disable mock fallbacks
# VITE_REQUIRE_API=true

# ── Safe-to-trade: reconciliation heal (default OFF = report-only) ─────────
# When set to 1, local OMS is repaired from broker truth (correct-then-heal).
# Never place/cancel on the exchange. Operator/SRE must opt in deliberately.
# TRADEX_RECONCILIATION_AUTO_REPAIR=0
