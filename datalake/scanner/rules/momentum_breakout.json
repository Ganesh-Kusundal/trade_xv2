{
  "name": "momentum_breakout",
  "version": "1.0",
  "description": "Find stocks with RSI > 60 and positive momentum (ROC_5 > 2%)",
  "universe": "NIFTY500",
  "timeframe": "1m",

  "select": [
    {"column": "symbol"},
    {"column": "rsi_14", "alias": "rsi"},
    {"column": "roc_5", "alias": "momentum_5d"},
    {"column": "atr_14", "alias": "atr"},
    {"expr": "(rsi_14 - 50) * 2 + roc_5 * 10", "alias": "raw_score"}
  ],

  "from": "v_intraday_snapshot",

  "where": [
    {"field": "rsi_14", "op": ">", "value": 60},
    {"field": "roc_5", "op": ">", "value": 2.0}
  ],

  "score": {
    "expr": "(rsi_14 - 50) * 2 + roc_5 * 10",
    "normalize": {"min": 0, "max": 100}
  },

  "reasons": [
    {"condition": "rsi_14 > 70 AND roc_5 > 5", "text": "Strong bullish momentum (RSI={rsi_14:.0f}, ROC={roc_5:.1f}%)"},
    {"condition": "rsi_14 > 60", "text": "Bullish momentum (RSI={rsi_14:.0f})"}
  ],

  "order_by": [{"field": "score", "direction": "DESC"}],
  "limit": 15
}
