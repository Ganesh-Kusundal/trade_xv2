// TradeXV2 v2 — Broker layered architecture (C4-L3/L4 hybrid)
// Source skill: system-modeler + graphviz
// Evidence: src/plugins/brokers/**, src/runtime/**, src/domain/ports/**
// Layout: rankdir=TB, one cluster per architectural layer.
//         Shows how a broker call crosses layer boundaries.
digraph broker_layers {
  rankdir=TB;
  nodesep=0.55;
  ranksep=0.8;
  fontname="Helvetica";
  node [fontname="Helvetica", fontsize=10, style=filled, fillcolor="#f5f5f5"];
  edge [fontname="Helvetica", fontsize=8];

  // =====================================================================
  // L0 — Application (strategy / risk / OMS)
  // =====================================================================
  subgraph cluster_L0 {
    label="L0 · application (strategy / risk / OMS) — uses BrokerAdapter only";
    style=filled; fillcolor="#eef7ee"; color="#3a7d3a";
    fontname="Helvetica"; fontsize=11;
    app [label="StrategyEngine · RiskManager · OrderManager\nExecutionEngine", shape=box, fillcolor="#d7ecd7"];
    fillsrc [label="BrokerFillSource (LIVE)\nPaperFillSource (PAPER)", shape=box, fillcolor="#d7ecd7"];
    app -> fillsrc [label="submit / cancel"];
  }

  // =====================================================================
  // L1 — Domain ports
  // =====================================================================
  subgraph cluster_L1 {
    label="L1 · domain ports — broker-agnostic contracts";
    style=filled; fillcolor="#eef2fb"; color="#3a5ca8";
    fontname="Helvetica"; fontsize=11;
    port_adapter [label="BrokerAdapter\n(Protocol)", shape=component, fillcolor="#d6e0f5"];
    port_transport [label="BaseTransport\n(Protocol)", shape=component, fillcolor="#d6e0f5"];
    port_fill [label="FillSource\n(Protocol)", shape=component, fillcolor="#d6e0f5"];
  }

  // =====================================================================
  // L2 — Runtime composition root (only place brokers are constructed)
  // =====================================================================
  subgraph cluster_L2 {
    label="L2 · runtime — composition root";
    style=filled; fillcolor="#fbf6ea"; color="#a8862f";
    fontname="Helvetica"; fontsize=11;
    factory  [label="build_broker_adapter()\nBrokerId → gateway", shape=box3d, fillcolor="#f5ecd0"];
    registry [label="registry.py\n_PLUGINS: dict[BrokerId, …]", shape=cylinder, fillcolor="#f5ecd0"];
    factory -> registry;
  }

  // =====================================================================
  // L3 — Broker plugins (gateways)
  // =====================================================================
  subgraph cluster_L3 {
    label="L3 · broker plugins — gateway facades";
    style=filled; fillcolor="#f7eef7"; color="#8a3a8a";
    fontname="Helvetica"; fontsize=11;
    g_paper  [label="PaperGateway", fillcolor="#ecd7ec"];
    g_dhan   [label="DhanGateway\n+ BrokerExtensions", fillcolor="#ecd7ec"];
    g_upstox [label="UpstoxGateway", fillcolor="#ecd7ec"];
  }

  // =====================================================================
  // L4 — Broker connections (own auth + transport + sub-adapters)
  // =====================================================================
  subgraph cluster_L4 {
    label="L4 · broker connections — auth + transport + 5-way adapter split";
    style=filled; fillcolor="#eef6f9"; color="#3a7d99";
    fontname="Helvetica"; fontsize=11;
    c_paper  [label="PaperConnection", fillcolor="#d5e9f2"];
    c_dhan   [label="DhanConnection\n(DhanTokenManager + limiter)", fillcolor="#d5e9f2"];
    c_upstox [label="UpstoxConnection\n(UpstoxTokenManager + limiter)", fillcolor="#d5e9f2"];
  }

  // =====================================================================
  // L5 — Sub-adapters + wire mappers (broker-specific)
  // =====================================================================
  subgraph cluster_L5 {
    label="L5 · sub-adapters + wire mappers (per broker)";
    style=filled; fillcolor="#f2f2f2"; color="#666666";
    fontname="Helvetica"; fontsize=11;
    adapters [label="{orders, market_data, portfolio,\n instruments, streaming}\n+ {DhanWire, UpstoxWire}", shape=box, fillcolor="#e4e4e4"];
  }

  // =====================================================================
  // L6 — Shared broker plumbing (common)
  // =====================================================================
  subgraph cluster_L6 {
    label="L6 · shared broker plumbing (common)";
    style=filled; fillcolor="#f2f2f2"; color="#666666";
    fontname="Helvetica"; fontsize=11;
    http     [label="HttpTransport\n(rate + circuit + retry + token)", fillcolor="#e4e4e4"];
    ws       [label="WsReconnectManager", fillcolor="#e4e4e4"];
    token    [label="TokenManager\n(store → env → TOTP)", fillcolor="#e4e4e4"];
    rate     [label="MultiBucketRateLimiter", fillcolor="#e4e4e4"];
    ext      [label="BrokerExtensions", fillcolor="#e4e4e4"];
  }

  // =====================================================================
  // L7 — External venues
  // =====================================================================
  subgraph cluster_L7 {
    label="L7 · external venues";
    style=filled; fillcolor="#fdeaea"; color="#b03030";
    fontname="Helvetica"; fontsize=11;
    dhan_rest   [label="Dhan REST", shape=cylinder, fillcolor="#f6d5d5"];
    dhan_ws     [label="Dhan WS", shape=cylinder, fillcolor="#f6d5d5"];
    upstox_rest [label="Upstox REST", shape=cylinder, fillcolor="#f6d5d5"];
    upstox_ws   [label="Upstox WS", shape=cylinder, fillcolor="#f6d5d5"];
  }

  // ===== layer-crossing edges =====
  app        -> port_adapter [label="depends-on"];
  fillsrc    -> port_adapter [label="delegates"];
  port_fill  -> port_adapter [label="uses"];
  factory    -> g_paper  [label="constructs"];
  factory    -> g_dhan   [label="constructs"];
  factory    -> g_upstox [label="constructs"];

  g_paper  -> c_paper  [label="owns"];
  g_dhan   -> c_dhan   [label="owns"];
  g_upstox -> c_upstox [label="owns"];

  c_paper  -> adapters [label="owns"];
  c_dhan   -> adapters [label="owns"];
  c_upstox -> adapters [label="owns"];

  adapters -> http [label="REST calls"];
  adapters -> ws   [label="WS feed"];
  c_dhan   -> token [label="builds"];
  c_upstox -> token [label="builds"];
  c_dhan   -> rate  [label="builds"];
  c_upstox -> rate  [label="builds"];

  http -> dhan_rest   [label="HTTPS", color="#b03030", style=dashed];
  http -> upstox_rest [label="HTTPS", color="#b03030", style=dashed];
  adapters -> dhan_ws   [label="WS", color="#7a3aa8", style=dotted];
  adapters -> upstox_ws [label="WS", color="#7a3aa8", style=dotted];
}
