# Live Upstox credentials — copy to config/upstox-live.properties (gitignored)
#
# Mirrors the Trade_J config/upstox-live.properties.example template.
#
#   upstox.live.clientId     — Upstox API key
#   upstox.live.clientSecret — Upstox API secret
#   upstox.live.redirectUri  — OAuth redirect URI
#   upstox.live.accessToken  — daily algo/access token (~12h lifetime, required for expired-instruments APIs)
#   upstox.live.analyticsToken — 1-year read-only analytics JWT (LTP, historical, option chain)
#
# Upstox is used by IntelligentGateway as a routing preference for LTP/Quote
# requests; falls back to Dhan on failure. The live trading path does NOT
# use Upstox as the active broker.
upstox.live.clientId=
upstox.live.clientSecret=
upstox.live.redirectUri=http://127.0.0.1:18080/callback
upstox.live.accessToken=
upstox.live.analyticsToken=

# TOTP Authentication (optional — for automated daily token refresh)
# To enable TOTP mode, set: upstox.authMode=TOTP
upstox.mobile=
upstox.pin=
upstox.totpSecret=
upstox.totpRefreshHour=8
upstox.totpRefreshMinute=0
