# TradeXV2 Web Terminal — environment

# Base URL of the FastAPI backend. Leave EMPTY to use the Vite dev
# proxy (recommended for `npm run dev`): requests go to "/api/..."
# and are proxied to http://127.0.0.1:8080. Set this when the
# SPA is served from a different origin than the backend.
VITE_API_BASE=

# WebSocket base URL. Leave empty to use the Vite proxy ("/ws").
VITE_WS_BASE=

# API key sent as the X-API-Key header. ONLY needed when the backend
# runs with AUTH_MODE=api_key (the default). When using the Vite proxy
# in dev the header is forwarded automatically. If you start the backend
# with AUTH_MODE=none (recommended for local paper dev) you can omit this.
VITE_API_KEY=
