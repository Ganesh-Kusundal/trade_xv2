    "import time\n",
    "\n",
    "from brokers.session import BrokerSession\n",
    "\n",
    "session = BrokerSession(\"paper\")\n",
    "start = time.perf_counter()\n",
    "session.stock(\"RELIANCE\").refresh()\n",
    "print(f\"quote latency: {(time.perf_counter() - start) * 1000:.1f}ms\")\n",
    "session.close()"
   ]
  }
